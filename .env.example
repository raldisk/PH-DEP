# ── ph-price-tracker environment configuration ───────────────────────────────
# Copy this file to .env and adjust values as needed.
# Never commit .env to version control — it is in .gitignore.

# ── Backend selection ─────────────────────────────────────────────────────────
# "duckdb"     → primary OLAP warehouse (default; recommended for dev + prod)
# "postgresql" → CI/integration only; requires a running PostgreSQL server
TRACKER_DB_BACKEND=duckdb

# ── DuckDB ────────────────────────────────────────────────────────────────────
TRACKER_DB_PATH=data/prices.duckdb

# ── PostgreSQL (only needed when TRACKER_DB_BACKEND=postgresql) ──────────────
TRACKER_POSTGRES_DSN=postgresql://tracker:tracker@localhost:5432/tracker

# ── HTTP scraper ──────────────────────────────────────────────────────────────
TRACKER_REQUEST_TIMEOUT=30
TRACKER_MAX_RETRIES=3
TRACKER_RETRY_BASE_DELAY=2.0
TRACKER_RATE_LIMIT_DELAY=1.5

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Max result pages per keyword (~50 items/page, so 3 pages ≈ 150 items/keyword)
TRACKER_MAX_PAGES_PER_KEYWORD=3

# Override search keywords (JSON array string)
# TRACKER_KEYWORDS=["laptop","smartphone","gaming monitor"]
