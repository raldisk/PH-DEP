# Copy to .env and fill in before running.
# Never commit .env to version control.

# Pipeline mode: 'simulate' (default, no API key) or 'live'
PH_SENTIMENT_MODE=simulate

# PostgreSQL
PH_SENTIMENT_POSTGRES_DSN=postgresql://sentiment:sentiment@localhost:5432/ph_sentiment
PH_SENTIMENT_PG_HOST=postgres
PH_SENTIMENT_PG_PORT=5432
PH_SENTIMENT_PG_USER=sentiment
PH_SENTIMENT_PG_PASSWORD=sentiment
PH_SENTIMENT_PG_DBNAME=ph_sentiment

# Kafka
PH_SENTIMENT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PH_SENTIMENT_KAFKA_TOPIC_TRENDS=ph.trends.raw
PH_SENTIMENT_KAFKA_TOPIC_TWEETS=ph.tweets.raw
PH_SENTIMENT_KAFKA_GROUP_ID=ph-sentiment-consumer

# Sentiment model (HuggingFace)
PH_SENTIMENT_SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment
PH_SENTIMENT_SENTIMENT_BATCH_SIZE=32
PH_SENTIMENT_USE_VADER_FALLBACK=true

# Twitter/X API (only needed in live mode — Basic tier required)
PH_SENTIMENT_TWITTER_BEARER_TOKEN=

# Simulation
PH_SENTIMENT_SIMULATION_REPLAY_DELAY_MS=100
PH_SENTIMENT_FIXTURES_DIR=fixtures
